generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DEV
  ADMIN
  SELLER
  USER
}

model User {
  id                 Int       @id @default(autoincrement())
  name               String
  email              String    @unique
  fone               String?
  password           String?
  googleId           String?   @unique 
  avatar             String?  
  role               Role      @default(USER)
  cpf                String?   @unique @db.VarChar(14)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?

  addresses          Address[]
  orders             Order[]
  authLogs           AuthLog[]
  contactMessages    ContactMessage[] 
  shippingQuotes     ShippingQuote[]
}

model Address {
  id           Int       @id @default(autoincrement())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  recipientName String   @db.VarChar(150)
  zipCode       String   @db.VarChar(20)
  street        String   @db.VarChar(200)
  number        String   @db.VarChar(20)
  complement    String?  @db.VarChar(100)
  neighborhood  String   @db.VarChar(100)
  city          String   @db.VarChar(100)
  state         String   @db.VarChar(2)

  isDefault    Boolean  @default(false)

  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
}

model AuthLog {
  id         Int       @id @default(autoincrement())
  email      String 
  success    Boolean 
  message    String 
  ipAddress  String? 
  userAgent  String? 
  createdAt  DateTime  @default(now())
  userId     Int?
  user       User?     @relation(fields: [userId], references: [id])
}

// =========================================================
// 🚀 INÍCIO DAS ALTERAÇÕES: MOTOR DINÂMICO DE PRODUTOS
// =========================================================

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique @db.VarChar(100)
  slug     String    @unique @db.VarChar(100)
  
  // 👉 NOVO: O "Cérebro" da Categoria. Aqui o Admin guarda as regras (quais listas usar)
  // Ex: { "hasColor": true, "hasSize": true, "palette": "CAMA_COLORS", "extras": ["Com Colchão"] }
  config   Json?     

  products Product[]
}

model Product {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  name        String    @db.VarChar(150)
  slug        String?   @unique @db.VarChar(150)
  description String?   @db.Text
  mainImage   String?

  isAvailable Boolean   @default(true)
  isFeatured  Boolean   @default(false) 

  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  
  variants    ProductVariant[]

  orderItems  OrderItem[]
}

model ProductVariant {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sku         String?   @db.VarChar(50)
  price       Decimal   @db.Decimal(10, 2)
  stock       Int       @default(0)
  isFeatured  Boolean   @default(false) 

  // 👉 NOVO: Substituímos as colunas engessadas por um JSON flexível!
  // Aqui o banco aceita TUDO que a Categoria mandar.
  // Ex: { "color": "CZ6", "size": "Casal", "lado": "Esquerdo", "modelo": "Nuvem" }
  attributes  Json      @default("{}")
  
  productId   Int
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  images      VariantImage[] 
  orderItems  OrderItem[]
}

model VariantImage {
  id          Int            @id @default(autoincrement())
  url         String
  
  variantId   Int
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

// 👉 AVISO: A tabela ProductImage antiga foi removida.
// Em um E-commerce Sênior, todas as imagens (exceto a capa principal)
// devem estar ligadas à Variante, não ao Produto solto.

// =========================================================
// 🚀 FIM DAS ALTERAÇÕES
// =========================================================

enum OrderStatus {
  PENDING 
  PAID 
  IN_PRODUCTION 
  SHIPPED 
  DELIVERED 
  CANCELED 
}

model Order {
  id            Int       @id @default(autoincrement())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  total         Decimal   @db.Decimal(10, 2) 
  shippingCost  Decimal   @default(0) @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)

  paymentMethod String?   @db.VarChar(50) 
  shippingFee   Decimal   @default(0) @db.Decimal(10, 2) 
  invoiceUrl    String?

  tid           String?   @unique

  userId        Int
  user          User      @relation(fields: [userId], references: [id])

  addressId     Int
  address       Address   @relation(fields: [addressId], references: [id])

  items         OrderItem[]
}

model OrderItem {
  id          Int       @id @default(autoincrement())
  quantity    Int 
  price       Decimal   @db.Decimal(10, 2) 

  orderId     Int
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   Int?
  product     Product?  @relation(fields: [productId], references: [id])

  variantId   Int
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  
  customData  Json?
}

enum VisualItemType {
  APLIQUE
  TECIDO
  PANTONE
  LENCOL
  SINTETICO
  SHOWROOM
}

enum ItemColor {
  AMARELO
  AZUL
  AZULAZ3
  AZULBEBE
  BEGE
  BRANCO
  CINZA
  LARANJA
  LILAS
  MOSTARDA
  PALHA
  PRATA
  ROSA
  ROSABEBE
  TIFFANY
  VERDE
  VERMELHO
}

enum ItemSize {
  FRONHA
  BERCO
  JUNIOR
  SOLTEIRO
  SOLTEIRAO
  VIUVA
  CASAL
  QUEEN
  KING
}

model VisualItem {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  name        String?   @db.VarChar(150)
  code        String    @unique @db.VarChar(50)
  imageUrl    String?
  
  type        VisualItemType
  
  color       ItemColor?
  size        ItemSize?
  
  inStock     Boolean   @default(true) 
  sequence    Int? 
  quantity    Int? 
  isExternal  Boolean   @default(false) 
  isTapete    Boolean   @default(false)
}

model ContactMessage {
  id          Int       @id @default(autoincrement())
  name        String
  email       String
  subject     String
  message     String    @db.Text
  read        Boolean   @default(false) 
  createdAt   DateTime  @default(now())
  userId      Int?     
  user        User?     @relation(fields: [userId], references: [id])
}

model Environment {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(150)
  cover       String   
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  images      EnvironmentImage[] 
}

model EnvironmentImage {
  id            Int         @id @default(autoincrement())
  url           String
  key           String?     
  environmentId Int
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
}

model ShippingQuote {
  id                Int       @id @default(autoincrement())
  createdAt         DateTime  @default(now()) 
  updatedAt         DateTime  @updatedAt
  
  quoteDetails      String?   @db.Text 
  customerName      String?   @db.VarChar(150)
  customerCpf       String?   @db.VarChar(14) 
  customerZipCode   String?   @db.VarChar(10)
  customerAddress   String?   @db.VarChar(255) 
  customerCity      String?   @db.VarChar(100) 
  customerState     String?   @db.VarChar(2)   

  createdById       Int
  createdBy         User      @relation(fields: [createdById], references: [id])

  isRequested       Boolean   @default(false)
  isConcluded       Boolean   @default(false)
  adminNotes        String?   @db.Text
  concludedAt       DateTime? 

  carrierName       String?   @db.VarChar(150) 
  deliveryDeadline  String?   @db.VarChar(50)
  volumeQuantity    Int?        
  shippingValue     Decimal?  @db.Decimal(10, 2) 
  weight            String?   @db.VarChar(50) 
  orderValue        Decimal?  @db.Decimal(10, 2) 
  bedSize           String?   @db.VarChar(100)
  
  hasWallProtector  Boolean   @default(false)
  wallProtectorSize String?   
  
  hasRug            Boolean   @default(false)
  rugSize           String?   @db.VarChar(100) 
  
  hasAccessories    Boolean   @default(false)
  accessoryQuantity Int?        
}